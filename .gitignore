# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/
.venv/
venv/

# Large / fetched data we don't want to commit
data/raw/sec_company_tickers.json
# ~18 MB Truth Social feed cache (regenerated each run)
data/raw/truth_archive.json
data/raw/manual_texts/*.fetched.txt

# Keep the small incremental state file, ignore other processed scratch.
data/processed/*
!data/processed/.gitkeep
!data/processed/truth_state.json

# Built site is regenerated by CI; don't commit it.
site/

# Keep sample outputs in the repo (they are the demo deliverable), but ignore
# any ad-hoc output dirs.
outputs_*/
